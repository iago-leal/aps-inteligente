# Gabarito de configuração (feature 003; RN-04: configuração fora do código).
# Copie para .env.local (não commitado) e ajuste se necessário.

# Conexão com o banco local (infra/compose.yaml: usuário aps, senha aps, banco aps_inteligente).
# Em produção/preview a integração Neon do Vercel Marketplace injeta esta variável (TLS na URL).
DATABASE_URL=postgres://aps:aps@localhost:5432/aps_inteligente

# Porta do host mapeada pelo compose (default 5432). Se já houver Postgres nessa porta,
# descomente com outra (ex.: 5433) e ajuste a porta da DATABASE_URL acima; para a suíte
# de teste, replique a DATABASE_URL ajustada em .env.test.local (o modo de teste ignora
# .env.local por design do loader do Next).
# POSTGRES_PORT=5432

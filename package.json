{
  "name": "aps-inteligente",
  "version": "0.1.0",
  "private": true,
  "description": "Website dedicado à prática médica na APS — plataforma guarda-chuva com calculadora de insulina DM2 100% client-side",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:api": "vitest run --config vitest.api.config.ts",
    "db:up": "docker compose --env-file .env.local -f infra/compose.yaml up -d --wait",
    "db:down": "docker compose --env-file .env.local -f infra/compose.yaml down -v",
    "db:psql": "docker compose --env-file .env.local -f infra/compose.yaml exec banco psql -U aps -d aps_inteligente",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@primer/primitives": "11.9.0",
    "@primer/react": "38.33.0",
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "fast-check": "4.9.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
